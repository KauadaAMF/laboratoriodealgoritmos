while True:
    idade = int(input("Digite a idade (0 a 150): "))
    if 0 <= idade <= 150:
        break
    else:
        print("Idade inválida. Tente novamente.")

while True:
    salario = float(input("Digite o salário (maior que 0): "))
    if salario > 0:
        break
    else:
        print("Salário inválido. Tente novamente.")

while True:
    sexo = input("Digite o sexo ('f' ou 'm'): ")
    if sexo == "f" or sexo == "m":
        break
    else:
        print("Sexo inválido. Tente novamente.")

while True:
    estado_civil = input("Digite o estado civil ('s', 'c', 'v', 'd'): ")
    if estado_civil == "s" or estado_civil == "c" or estado_civil == "v" or estado_civil == "d":
        print("Idade: ", idade)
        print("Salário: R$ ", salario)
        print("Sexo: ", sexo)
        print("Estado civil: ", estado_civil)
        break
    else:
        print("Estado civil inválido. Tente novamente.")
