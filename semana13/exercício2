def calcular_media(lista):
    soma = 0
    for valor in lista:
        soma += valor
    media = soma / len(lista)
    return media

producao = []

i = 0
while i < 8:
    valor = float(input("Digite a produção de azeitonas do dia em kg: "))
    producao.append(valor)
    i += 1

media = calcular_media(producao)
print("A média de produção é: ", media)

print("Produções acima da média:")
for valor in producao:
    if valor > media:
        print(valor)
